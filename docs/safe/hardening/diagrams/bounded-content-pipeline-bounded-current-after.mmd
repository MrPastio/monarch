flowchart LR
  U["Untrusted imported file"]

  subgraph R["Safe renderer boundary"]
    UI["Safe renderer"]
    ROUTE["Allowlisted preview routing"]
    BOUNDED["4 MiB text, 64 KiB HEX, bounded PDF summary"]
    CHROMIUM["Chromium image and media decoders"]
    POLICY["Network, popup, clipboard, and mutation denials"]
  end

  subgraph V["Safe runtime boundary"]
    API["Vault content API"]
    CAP["Explicit 256 MiB operating cap"]
    ARCHIVE["Bounded synchronous whole-buffer archive codec"]
    METRICS["Resource and rejection telemetry"]
  end

  subgraph S["Encrypted storage boundary"]
    GENERATION["Authenticated immutable blob generation"]
    MANIFEST["Authenticated manifest"]
  end

  U -->|"complete File bytes"| UI
  UI -->|"whole-buffer import"| API
  CAP --> API
  API -->|"encrypt complete buffer"| GENERATION
  API --> MANIFEST
  GENERATION -->|"decrypt complete buffer"| API
  API -->|"complete plaintext response"| UI
  UI --> ROUTE
  POLICY --> ROUTE
  ROUTE --> BOUNDED
  ROUTE -->|"complete object URL"| CHROMIUM
  API <--> ARCHIVE
  API --> METRICS
