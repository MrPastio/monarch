{
  "name": "monarch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first AI ecosystem architecture kernel.",
  "scripts": {
    "node:check": "powershell -ExecutionPolicy Bypass -File scripts/ensure-node.ps1",
    "node:check:strict": "powershell -ExecutionPolicy Bypass -File scripts/ensure-node.ps1 -StrictActive",
    "node:install": "powershell -ExecutionPolicy Bypass -File scripts/ensure-node.ps1 -Install",
    "node:exec": "scripts\\node-exec.cmd",
    "start": "npm run node:exec -- tsx src/main.ts serve",
    "desktop": "electron desktop/electron/main.mjs",
    "desktop:smoke": "electron desktop/electron/main.mjs --smoke",
    "safe:entry:qa": "electron desktop/electron/main.mjs --safe-entry-qa",
    "safe:qa": "electron desktop/safe/qa.mjs",
    "ui": "npm run node:exec -- tsx src/main.ts serve",
    "status": "npm run node:exec -- tsx src/main.ts status",
    "intent": "npm run node:exec -- tsx src/main.ts intent",
    "system": "npm run node:exec -- tsx src/main.ts system",
    "oscar:install": "powershell -ExecutionPolicy Bypass -File oscar/scripts/install.ps1",
    "oscar:small-model": "powershell -ExecutionPolicy Bypass -File oscar/scripts/download-small-model.ps1",
    "oscar:backend": "powershell -ExecutionPolicy Bypass -File oscar/scripts/backend.ps1",
    "oscar:backend:mock": "powershell -ExecutionPolicy Bypass -File oscar/scripts/backend-mock.ps1",
    "oscar:frontend": "powershell -ExecutionPolicy Bypass -File oscar/scripts/frontend.ps1",
    "oscar:frontend:build": "npm run node:exec -- npm --prefix oscar/frontend run build",
    "oscar:test": "powershell -ExecutionPolicy Bypass -File oscar/scripts/test.ps1",
    "oscar:build-desktop": "powershell -ExecutionPolicy Bypass -File oscar/scripts/build-desktop.ps1",
    "voice:setup": "powershell -ExecutionPolicy Bypass -File tools/setup-neural-tts.ps1",
    "voice:stt:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/setup-sherpa-t-one-stt.ps1",
    "security": "powershell -ExecutionPolicy Bypass -File security/monarch_sec.ps1",
    "security:setup": "powershell -ExecutionPolicy Bypass -File security/scripts/setup_runtime.ps1",
    "security:setup:dev": "powershell -ExecutionPolicy Bypass -File security/scripts/setup_runtime.ps1 -WithDev",
    "security:status": "powershell -ExecutionPolicy Bypass -File security/monarch_sec.ps1 status",
    "security:start": "powershell -ExecutionPolicy Bypass -File security/monarch_sec.ps1 start --no-llm",
    "security:stop": "powershell -ExecutionPolicy Bypass -File security/monarch_sec.ps1 stop",
    "security:scan-system": "powershell -ExecutionPolicy Bypass -File security/monarch_sec.ps1 scan-system --summary-only --no-llm",
    "security:verify-integrity": "powershell -ExecutionPolicy Bypass -File security/monarch_sec.ps1 verify-integrity",
    "security:test": "powershell -ExecutionPolicy Bypass -File security/scripts/test.ps1",
    "build:runtime": "npm run node:exec -- npm run build:runtime:raw",
    "build:runtime:raw": "node scripts/build-runtime-bundle.mjs",
    "build:launcher": "powershell -ExecutionPolicy Bypass -File scripts/build-launcher.ps1",
    "install:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/bootstrap.ps1",
    "installer:build": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/build-installer.ps1",
    "export:public": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export-public.ps1",
    "upload:dry-run": "powershell -ExecutionPolicy Bypass -File scripts/upload-dry-run.ps1",
    "audit:root": "npm audit --omit=optional --audit-level=moderate",
    "audit:oscar-frontend": "npm --prefix oscar/frontend audit --omit=optional --audit-level=moderate",
    "audit:all": "npm run audit:root && npm run audit:oscar-frontend",
    "smoke": "npm run node:exec -- tsx src/smoke.ts",
    "smoke:raw": "tsx src/smoke.ts",
    "test": "npm run node:exec -- vitest run",
    "test:raw": "vitest run",
    "typecheck": "npm run node:exec -- tsc --noEmit",
    "typecheck:raw": "tsc --noEmit",
    "verify": "npm run node:exec -- npm run verify:raw",
    "verify:raw": "npm run typecheck:raw && npm run test:raw && npm run smoke:raw && npm run desktop:smoke && npm run safe:entry:qa && npm run safe:qa && npm run oscar:frontend:build",
    "verify:full": "npm run node:exec -- npm run verify:full:raw",
    "verify:full:raw": "npm run verify:raw && npm run oscar:test && npm run security:test && npm run upload:dry-run && npm run audit:all"
  },
  "engines": {
    "node": ">=22.12.0 <25",
    "npm": ">=10.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^42.0.0",
    "esbuild": "^0.28.1",
    "playwright-core": "^1.59.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "undici": "^7.28.0"
  },
  "optionalDependencies": {
    "sherpa-onnx-node": "1.13.4"
  }
}
