# Paths are portable by default and resolve from the Oscar project directory.
# Uncomment only when the models or data live outside the Monarch directory.
# OSCAR_MODEL_PATH=D:\MonarchModels\Gemma_12B\gemma-4-12B-it-Q4_K_M.gguf
# OSCAR_GEMMA_MODELS_DIR=D:\MonarchModels
# OSCAR_DB_PATH=D:\MonarchData\Oscar\memory\oscar_memory.sqlite3
# OSCAR_OFFLOAD_DIR=D:\MonarchData\Oscar\offload
OSCAR_PORT=7861

# 0 = real local model, 1 = fast UI/API test without loading weights
OSCAR_MOCK_MODEL=0
OSCAR_MOCK_FALLBACK=1
OSCAR_AUTO_UNLOAD_AFTER_GENERATION=1
OSCAR_RECYCLE_BACKEND_AFTER_GENERATION=1
OSCAR_SUPPRESS_LLAMA_LOGS=1
OSCAR_TRY_GPT_OSS_ON_LOW_VRAM=0

# Conservative defaults. Tune them after installation for the target machine.
OSCAR_GPU_MEMORY_GB=6
OSCAR_CPU_MEMORY_GB=16
OSCAR_CPU_THREADS=8
OSCAR_ATTENTION_IMPLEMENTATION=eager
OSCAR_GEMMA_SPECULATIVE_DECODING=1
OSCAR_GEMMA_DRAFT_MODE=mtp
OSCAR_GEMMA_DRAFT_NUM_PRED_TOKENS=4
OSCAR_GEMMA_DRAFT_GPU_LAYERS=8

OSCAR_DEFAULT_MAX_NEW_TOKENS=65536
OSCAR_DEFAULT_TEMPERATURE=0.3
OSCAR_DEFAULT_TOP_P=0.9
OSCAR_REPETITION_PENALTY=1.08
OSCAR_NO_REPEAT_NGRAM_SIZE=4
OSCAR_RETRIEVAL_K=6
OSCAR_SEARCH_TOP_K=5
